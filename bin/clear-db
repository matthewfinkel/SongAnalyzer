#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DB_PATH="$HOME/.audio_analyzer.db"

if [ ! -f "$DB_PATH" ]; then
    echo "Database not found at $DB_PATH — nothing to clear."
    exit 0
fi

echo "This will delete all songs from $DB_PATH."
echo "The genre tag vocabulary will be kept."
echo ""
read -r -p "Are you sure? [y/N] " confirm
if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    echo "Aborted."
    exit 0
fi

sqlite3 "$DB_PATH" "DELETE FROM songs;"
echo "Done. All songs removed from the database."
